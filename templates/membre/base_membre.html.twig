{% extends 'base.html.twig' %}

{% block body %}
<div class="layout-sidebar">

    {# ===== SIDEBAR ===== #}
    <nav class="sidebar">
        <div class="px-4 py-3 mb-2 d-flex align-items-center gap-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width:42px;height:42px;background:var(--orange);font-family:'Montserrat',sans-serif;font-weight:700;color:#fff;font-size:1rem">
                M
            </div>
            <div>
                <div style="color:#fff;font-weight:600;font-size:.9rem">Joachin Phoenix</div>
                <div style="color:rgba(255,255,255,.45);font-size:.75rem">Membre</div>
            </div>
        </div>

        <div class="sidebar-title">Mon espace</div>
        <a href="{{ path('app_membre_dashboard') }}"   class="{{ app.request.attributes.get('_route') == 'app_membre_dashboard'   ? 'active' : '' }}"><i class="fa-solid fa-gauge-high"></i> Tableau de bord</a>
        <a href="{{ path('app_membre_profil') }}"       class="{{ app.request.attributes.get('_route') == 'app_membre_profil'       ? 'active' : '' }}"><i class="fa-solid fa-user"></i> Mon profil</a>

        <div class="sidebar-title">Mes chiens</div>
        <a href="{{ path('app_membre_chiens') }}"       class="{{ app.request.attributes.get('_route') starts with 'app_membre_chien' ? 'active' : '' }}"><i class="fa-solid fa-dog"></i> Mes chiens</a>
        <a href="{{ path('app_membre_chien_new') }}"   class="{{ app.request.attributes.get('_route') == 'app_membre_chien_new'    ? 'active' : '' }}"><i class="fa-solid fa-plus"></i> Ajouter un chien</a>

        <div class="sidebar-title">Inscription</div>
        <a href="{{ path('app_membre_seances') }}"      class="{{ app.request.attributes.get('_route') == 'app_membre_seances'      ? 'active' : '' }}"><i class="fa-solid fa-calendar-days"></i> Séances disponibles</a>
        <a href="{{ path('app_membre_inscriptions') }}" class="{{ app.request.attributes.get('_route') == 'app_membre_inscriptions' ? 'active' : '' }}"><i class="fa-solid fa-list-check"></i> Mes inscriptions</a>

        <div class="sidebar-title">Compte</div>
        <a href="{{ path('app_logout') }}" style="color: #f87171"><i class="fa-solid fa-right-from-bracket"></i> Déconnexion</a>
    </nav>

    {# ===== CONTENU ===== #}
    <div class="content-area">
        {% block membre_body %}{% endblock %}
    </div>

</div>
{% endblock %}
