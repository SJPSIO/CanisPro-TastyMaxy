{% extends 'membre/base_membre.html.twig' %}

{% block title %}Mon espace – CanisPro{% endblock %}

{% block membre_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">
        Bonjour, {{ proprietaire.prenom|default('Utilisateur') }}
    </h2>
    <p class="text-muted">Bienvenue dans votre espace personnel CanisPro.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-orange">
            <div class="stat-number">{{ nbChiens }}</div>
            <div class="stat-label">Mes chiens</div>
            <i class="fa-solid fa-dog stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-dark">
            <div class="stat-number">{{ nbInscriptionsActives }}</div>
            <div class="stat-label">Inscriptions actives</div>
            <i class="fa-solid fa-list-check stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-blue">
            <div class="stat-number">{{ nbSeancesDisponibles }}</div>
            <div class="stat-label">Séances disponibles</div>
            <i class="fa-solid fa-calendar-days stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-green">
            <div class="stat-number">{{ nbSeancesSuivies }}</div>
            <div class="stat-label">Séances suivies</div>
            <i class="fa-solid fa-trophy stat-icon"></i>
        </div>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-7">
        <div class="card card-canis">
            <div class="card-body p-4">
                <h5 style="font-family:'Montserrat',sans-serif;font-weight:700;margin-bottom:20px">
                    <i class="fa-solid fa-calendar-check me-2" style="color:var(--orange)"></i>Mes prochaines séances
                </h5>

                {% if prochainesInscriptions is empty %}
                    <p class="text-muted mb-0">Aucune inscription pour le moment.</p>
                {% else %}
                    <div class="table-canis">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Cours</th>
                                    <th>Chien</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for inscription in prochainesInscriptions %}
                                    <tr>
                                        <td>{{ inscription.seance.cours.titre }}</td>
                                        <td>
                                            <span class="badge" style="background:var(--orange-pale);color:var(--orange)">
                                                {{ inscription.chien.nom }}
                                            </span>
                                        </td>
                                        <td>{{ inscription.seance.dateHeure|date('d/m/Y') }} – {{ inscription.seance.dateHeure|date('H:i') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                <a href="{{ path('app_membre_inscriptions') }}" class="btn btn-outline-canispro btn-sm mt-3">
                    Voir toutes mes inscriptions
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-canis">
            <div class="card-body p-4">
                <h5 style="font-family:'Montserrat',sans-serif;font-weight:700;margin-bottom:20px">
                    <i class="fa-solid fa-dog me-2" style="color:var(--orange)"></i>Mes chiens
                </h5>

                {% if chiens is empty %}
                    <p class="text-muted mb-3">Aucun chien enregistré.</p>
                {% else %}
                    {% for chien in chiens|slice(0, 3) %}
                        <div class="d-flex align-items-center gap-3 py-2 {% if not loop.last %}mb-2{% endif %}"
                             style="{% if not loop.last %}border-bottom:1px solid #f0f0f0{% endif %}">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:44px;height:44px;background:var(--orange-pale);font-size:1.2rem"></div>
                            <div>
                                <div class="fw-bold">{{ chien.nom }}</div>
                                <div class="text-muted" style="font-size:.82rem">
                                    {{ chien.race }}{% if chien.dateNaissance %} · né le {{ chien.dateNaissance|date('d/m/Y') }}{% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

                <a href="{{ path('app_membre_chiens') }}" class="btn btn-outline-canispro btn-sm mt-3 me-2">Gérer mes chiens</a>
                <a href="{{ path('app_membre_chien_new') }}" class="btn btn-canispro btn-sm mt-3">
                    <i class="fa-solid fa-plus me-1"></i>Ajouter
                </a>
            </div>
        </div>
    </div>

</div>

{% endblock %}