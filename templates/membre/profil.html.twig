{% extends 'membre/base_membre.html.twig' %}

{% block title %}Mon profil – CanisPro{% endblock %}

{% block membre_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Mon profil</h2>
    <p class="text-muted">Gérez vos informations personnelles</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-canis">
            <div class="card-body p-4">
                <h5 style="font-family:'Montserrat',sans-serif;font-weight:700;margin-bottom:24px">
                    <i class="fa-solid fa-user me-2" style="color:var(--orange)"></i>Informations du propriétaire
                </h5>
                <form class="form-canis">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Prénom</label>
                            <input type="text" class="form-control" value="{{ app.user.proprietaire.prenom|default('error') }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nom</label>
                            <input type="text" class="form-control" value="{{ app.user.proprietaire.nom|default('error') }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Téléphone</label>
                            <input type="tel" class="form-control" value="{{ app.user.proprietaire.telephone|default('error') }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" value="{{ app.user.email|default('error') }}" readonly disabled>
                            <div class="form-text">L'email ne peut pas être modifié ici.</div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-canispro">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Enregistrer les modifications
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card card-canis text-center p-4">
            <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
                 style="width:80px;height:80px;background:var(--orange);font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.8rem;color:#fff">
                {{ app.user.proprietaire.prenom|first }}{{ app.user.proprietaire.nom|first }}
            </div>
            <h5 style="font-family:'Montserrat',sans-serif;font-weight:700">{{ app.user.proprietaire.prenom }} {{ app.user.proprietaire.nom }}</h5>
            <span class="badge rounded-pill mb-3" style="background:var(--orange-pale);color:var(--orange)">Membre</span>
            <p class="text-muted" style="font-size:.85rem">
                <i class="fa-solid fa-envelope me-2" style="color:var(--orange)"></i>{{ app.user.email }}<br>
                <i class="fa-solid fa-phone me-2 mt-2 d-inline-block" style="color:var(--orange)"></i>{{ app.user.proprietaire.telephone }}
            </p>
        </div>
    </div>
</div>

{% endblock %}
