{% extends 'membre/base_membre.html.twig' %}

{% block title %}Mes chiens – CanisPro{% endblock %}

{% block membre_body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Mes chiens</h2>
        <p class="text-muted mb-0">
            {{ chiens|length }} chien{% if chiens|length > 1 %}s{% endif %} enregistré{% if chiens|length > 1 %}s{% endif %}
        </p>
    </div>
    <a href="{{ path('app_membre_chien_new') }}" class="btn btn-canispro">
        <i class="fa-solid fa-plus me-2"></i>Ajouter un chien
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
{% endfor %}

{% if chiens is empty %}
    <div class="card card-canis text-center p-5">
        <i class="fa-solid fa-dog fa-3x text-muted mb-3"></i>
        <h5>Aucun chien enregistré</h5>
        <p class="text-muted">Ajoutez votre premier chien pour pouvoir vous inscrire aux séances.</p>
        <a href="{{ path('app_membre_chien_new') }}" class="btn btn-canispro mx-auto" style="width:fit-content">
            <i class="fa-solid fa-plus me-2"></i>Ajouter un chien
        </a>
    </div>
{% else %}
    <div class="row g-4">
        {% for chien in chiens %}
            <div class="col-md-6 col-xl-4">
                <div class="card card-canis h-100 position-relative chien-card">

                    <form method="post"
                          action="{{ path('app_membre_chien_delete', {id: chien.id}) }}"
                          class="delete-chien-form"
                          onsubmit="return confirm('Voulez-vous vraiment supprimer ce chien ?');">
                        <button type="submit" class="btn-delete-chien" title="Supprimer ce chien">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </form>

                    <div style="height:6px;background:linear-gradient(90deg,var(--orange),var(--orange-light))"></div>

                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                 style="width:56px;height:56px;background:var(--orange-pale);font-size:1.8rem"></div>
                            <div>
                                <h4 style="font-family:'Montserrat',sans-serif;font-size:1.2rem;font-weight:700;margin-bottom:2px">
                                    {{ chien.nom }}
                                </h4>
                                <span style="color:var(--grey);font-size:.85rem">{{ chien.race }}</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid #f0f0f0;font-size:.9rem">
                            <span class="text-muted">Date de naissance</span>
                            <strong>{{ chien.dateNaissance ? chien.dateNaissance|date('d/m/Y') : '-' }}</strong>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <a href="{{ path('app_membre_chien_edit', {id: chien.id}) }}" class="btn btn-outline-canispro btn-sm flex-fill">
                                <i class="fa-solid fa-pen me-1"></i>Modifier
                            </a>
                            <a href="{{ path('app_membre_seances') }}" class="btn btn-canispro btn-sm flex-fill">
                                <i class="fa-solid fa-calendar-plus me-1"></i>Inscrire
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

<style>
.chien-card .delete-chien-form {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.chien-card:hover .delete-chien-form {
    opacity: 1;
}

.btn-delete-chien {
    width: 34px;
    height: 34px;
    border: none;
    border-radius: 50%;
    background: #fff;
    color: #dc3545;
    box-shadow: 0 4px 10px rgba(0,0,0,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.btn-delete-chien:hover {
    background: #dc3545;
    color: #fff;
}
</style>

{% endblock %}