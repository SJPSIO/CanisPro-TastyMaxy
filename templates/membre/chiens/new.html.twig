{% extends 'membre/base_membre.html.twig' %}

{% block title %}Ajouter un chien – CanisPro{% endblock %}

{% block membre_body %}

<div class="mb-4">
    <a href="{{ path('app_membre_chiens') }}" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Ajouter un chien</h2>
    <p class="text-muted">Enregistrez un nouveau compagnon dans votre espace</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-canis">
            <div class="card-body p-4">
                {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.race) }}
                    {{ form_widget(form.race, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.dateNaissance) }}
                    {{ form_widget(form.dateNaissance, {'attr': {'class': 'form-control'}}) }}
                </div>

                <button class="btn btn-canispro">
                    Ajouter le chien
                </button>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}
