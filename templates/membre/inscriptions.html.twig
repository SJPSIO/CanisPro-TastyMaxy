{% extends 'membre/base_membre.html.twig' %}

{% block title %}Mes inscriptions – CanisPro{% endblock %}

{% block membre_body %}

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
{% endfor %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Mes inscriptions</h2>
    <p class="text-muted">Toutes vos inscriptions aux séances</p>
</div>

{% if inscriptions is empty %}
<div class="card card-canis text-center p-5">
    <i class="fa-solid fa-list-check fa-3x text-muted mb-3"></i>
    <h5>Aucune inscription</h5>
    <p class="text-muted">Vous n'êtes encore inscrit à aucune séance.</p>
    <a href="{{ path('app_membre_seances') }}" class="btn btn-canispro mx-auto" style="width:fit-content">
        <i class="fa-solid fa-calendar-plus me-2"></i>Voir les séances
    </a>
</div>
{% else %}
<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Cours</th>
                <th>Chien</th>
                <th>Date séance</th>
                <th>Lieu</th>
                <th>Inscrit le</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for inscription in inscriptions %}
            <tr>
                <td><strong>{{ inscription.seance.cours.titre }}</strong></td>
                <td>
                    <span class="badge" style="background:var(--orange-pale);color:var(--orange)">
                        {{ inscription.chien.nom }}
                    </span>
                </td>
                <td>
                    <i class="fa-regular fa-calendar me-1 text-muted"></i>
                    {{ inscription.seance.dateHeure|date('d/m/Y') }} à {{ inscription.seance.dateHeure|date('H:i') }}
                </td>
                <td>
                    <i class="fa-solid fa-location-dot me-1 text-muted"></i>{{ inscription.seance.lieu }}
                </td>
                <td class="text-muted" style="font-size:.85rem">
                    {{ inscription.dateInscription|date('d/m/Y') }}
                </td>
                <td>
                    <form method="post"
                        action="{{ path('app_membre_inscription_delete', {id: inscription.id}) }}"
                        onsubmit="return confirm('Voulez-vous vraiment annuler cette inscription ?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-trash me-1"></i>Annuler
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a href="{{ path('app_membre_seances') }}" class="btn btn-canispro">
        <i class="fa-solid fa-calendar-plus me-2"></i>Inscrire un chien à une nouvelle séance
    </a>
</div>
{% endif %}

{% endblock %}
