{% extends 'admin/base_admin.html.twig' %}

{% block title %}Propriétaires – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des propriétaires</h2>
    <p class="text-muted mb-0">{{ proprietaires|length }} propriétaires enregistrés</p>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom complet</th>
                <th>Téléphone</th>
                <th>Email</th>
                <th>Chiens</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for p in proprietaires %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ p.id }}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:34px;height:34px;background:var(--orange-pale);font-size:.75rem;font-weight:700;color:var(--orange)">
                            {{ p.prenom|first }}{{ p.nom|first }}
                        </div>
                        <strong>{{ p.prenom }} {{ p.nom }}</strong>
                    </div>
                </td>
                <td>{{ p.telephone }}</td>
                <td class="text-muted" style="font-size:.88rem">{{ p.email }}</td>
                <td><span class="badge bg-secondary">{{ p.nbChiens }} chien{% if p.nbChiens > 1 %}s{% endif %}</span></td>
                <td>
                    <form method="POST" action="{{ path('admin_proprietaire_supprimer', {id: p.id}) }}"
                        onsubmit="return confirm('Voulez-vous vraiment supprimer ce propriétaire ?');" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.id) }}">
                        <button type="submit" class="btn-action btn-action-delete" title="Supprimer">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
