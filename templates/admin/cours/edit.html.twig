{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier cours – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <a href="{{ path('app_admin_cours') }}" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Modifier le cours</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card card-canis">
            <div class="card-body p-4">
                <form class="form-canis" method="POST"> <div class="mb-3">
                        <label class="form-label">Titre du cours</label>
                        <input type="text" name="titre" class="form-control" value="{{ cours.titre }}"> </div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label">Type</label>
                            <select name="type" class="form-select"> <option value="Individuel" {% if cours.type == 'Individuel' %}selected{% endif %}>Individuel</option>
                                <option value="Collectif" {% if cours.type == 'Collectif' %}selected{% endif %}>Collectif</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Niveau</label>
                            <select name="niveau" class="form-select"> <option value="Chiot" {% if cours.niveau == 'Chiot' %}selected{% endif %}>Chiot</option>
                                <option value="Débutant" {% if cours.niveau == 'Débutant' %}selected{% endif %}>Débutant</option>
                                <option value="Confirmé" {% if cours.niveau == 'Confirmé' %}selected{% endif %}>Confirmé</option>
                                <option value="Tous niveaux" {% if cours.niveau == 'Tous niveaux' %}selected{% endif %}>Tous niveaux</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="4">{{ cours.description }}</textarea> </div>

                    <div class="mb-4">
                        <label class="form-label">Prix par séance (€)</label>
                        <input type="number" name="prix" class="form-control" step="0.01" value="{{ cours.prix }}"> </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-canispro">Enregistrer</button>
                        <a href="{{ path('app_admin_cours') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}
