{% extends 'admin/base_admin.html.twig' %}

{% block title %}Utilisateurs – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des utilisateurs</h2>
    <p class="text-muted mb-0">{{ utilisateurs|length }} comptes enregistrés</p>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Propriétaire lié</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for u in utilisateurs %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ u.id }}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:34px;height:34px;background:var(--orange-pale);font-size:.8rem;font-weight:700;color:var(--orange)">
                            {{ u.email|first|upper }}
                        </div>
                        {{ u.email }}
                    </div>
                </td>
                <td>
                    {% if 'ROLE_ADMIN' in u.roles %}
                        <span class="badge" style="background:var(--dark);color:#fff">Admin</span>
                    {% else %}
                        <span class="badge" style="background:var(--orange-pale);color:var(--orange)">Membre</span>
                    {% endif %}
                </td>
                <td>{% if u.proprietaire %}{{ u.proprietaire }}{% else %}<span class="text-muted">—</span>{% endif %}</td>
                <td>
                    <button type="button" class="btn-action btn-action-delete" title="Supprimer">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
