{% extends 'admin/base_admin.html.twig' %}

{% block title %}Chiens – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des chiens</h2>
    <p class="text-muted mb-0">{{ chiens|length }} chiens enregistrés</p>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Race</th>
                <th>Propriétaire</th>
                <th>Naissance</th>
                <th>Inscriptions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for c in chiens %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ c.id }}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <span style="font-size:1.2rem"></span>
                        <strong>{{ c.nom }}</strong>
                    </div>
                </td>
                <td>{{ c.race }}</td>
                <td>
                    {% if c.proprietaire %}
                        {{ c.proprietaire.prenom }} {{ c.proprietaire.nom }}
                    {% else %}
                        <span class="text-muted">Aucun</span>
                    {% endif %}
                </td>
                <td>{{ c.dateNaissance ? c.dateNaissance|date('d/m/Y') : 'N/A' }}</td>
                <td><span class="badge bg-secondary">{{ c.nb_inscriptions ?? 0 }}</span></td>
                <td>
                    <form method="POST" action="{{ path('admin_chien_supprimer', {id: c.id}) }}"
                        onsubmit="return confirm('Voulez-vous vraiment supprimer ce chien ?');" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ c.id) }}">
                        <button type="submit" class="btn-action btn-action-delete" title="Supprimer">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
