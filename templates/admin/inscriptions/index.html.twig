{% extends 'admin/base_admin.html.twig' %}

{% block title %}Inscriptions – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des inscriptions</h2>
    <p class="text-muted mb-0">{{ inscriptions|length }} inscriptions enregistrées</p>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Chien</th>
                <th>Propriétaire</th>
                <th>Cours</th>
                <th>Date séance</th>
                <th>Date inscription</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for i in inscriptions %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ i.id }}</td>
                <td><span class="badge" style="background:var(--orange-pale);color:var(--orange)"> {{ i.chien }}</span></td>
                <td>{{ i.proprietaire }}</td>
                <td><strong>{{ i.cours }}</strong></td>
                <td>{{ i.date_seance|date('d/m/Y') }} à {{ i.heure }}</td>
                <td class="text-muted" style="font-size:.82rem">{{ i.date_inscription|date('d/m/Y') }}</td>
                <td>
                    <button type="button" class="btn-action btn-action-delete" title="Supprimer">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
