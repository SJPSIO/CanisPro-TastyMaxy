{% extends 'admin/base_admin.html.twig' %}

{% block title %}Inscriptions – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des inscriptions</h2>
    <p class="text-muted mb-0">{{ inscriptions|length }} inscriptions enregistrées</p>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Chien</th>
                <th>Propriétaire</th>
                <th>Cours</th>
                <th>Date séance</th>
                <th>Date inscription</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for i in inscriptions %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ i.id }}</td>
                
                {# On accède au nom du chien via l'objet Chien #}
                <td><span class="badge" style="background:var(--orange-pale);color:var(--orange)"> {{ i.chien.nom }}</span></td>
                
                {# On remonte du chien vers le propriétaire #}
                <td>{{ i.chien.proprietaire.nom }} {{ i.chien.proprietaire.prenom }}</td>
                
                {# On passe par la séance pour avoir le titre du cours #}
                <td><strong>{{ i.seance.cours.titre }}</strong></td>
                
                {# Formatage de la date et heure de la séance #}
                <td>{{ i.seance.dateHeure|date('d/m/Y') }} à {{ i.seance.dateHeure|date('H:i') }}</td>
                
                {# Date de création de l'entité Inscription #}
                <td class="text-muted" style="font-size:.82rem">{{ i.dateInscription|date('d/m/Y') }}</td>
                
                <td>
                    {# Formulaire de suppression sécurisé par CSRF #}
                    <form method="post" action="{{ path('admin_inscription_supprimer', {'id': i.id}) }}" onsubmit="return confirm('Supprimer cette inscription ?');" style="display:inline-block">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ i.id) }}">
                        <button type="submit" class="btn-action btn-action-delete" title="Supprimer">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="text-center">Aucune inscription trouvée.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}