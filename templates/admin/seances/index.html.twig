{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des séances – Admin{% endblock %}

{% block admin_body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Gestion des séances</h2>
        <p class="text-muted mb-0">{{ seances|length }} séances planifiées</p>
    </div>
    <a href="{{ path('app_admin_seance_new') }}" class="btn btn-canispro">
        <i class="fa-solid fa-plus me-2"></i>Nouvelle séance
    </a>
</div>

<div class="table-canis">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Cours</th>
                <th>Date</th>
                <th>Heure</th>
                <th>Lieu</th>
                <th>Inscriptions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for s in seances %}
            <tr>
                <td class="text-muted" style="font-size:.85rem">{{ s.id }}</td>
                {# Utilise getCours() (et le __toString de Cours) #}
                <td><strong>{{ s.cours }}</strong></td>
                {# Utilise getDateHeure() #}
                <td>{{ s.dateHeure|date('d/m/Y') }}</td>
                <td>{{ s.dateHeure|date('H:i') }}</td>
                {# Utilise getLieu() (que tu as ajouté à l'entité) #}
                <td>{{ s.lieu }}</td>
                <td>
                    {# Calcul dynamique : compte les éléments dans la collection inscriptions #}
                    {% set nbInscrits = s.inscriptions|length %}
                    {% set maxPlaces = s.nbPlacesMax %}
                    {% set pct = (maxPlaces > 0) ? (nbInscrits / maxPlaces * 100) : 0 %}
                    
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-fill" style="height:6px;width:80px">
                            <div class="progress-bar" style="width:{{ pct }}%;background:{% if pct >= 100 %}#dc3545{% elseif pct >= 70 %}#ffc107{% else %}var(--orange, #f39c12){% endif %}"></div>
                        </div>
                        <span style="font-size:.82rem;white-space:nowrap">{{ nbInscrits }}/{{ maxPlaces }}</span>
                    </div>
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_admin_seance_edit', {id: s.id}) }}" class="btn-action btn-action-edit" title="Modifier">
                            <i class="fa-solid fa-pen"></i>
                        </a>
                        
                        {# Formulaire de suppression avec token CSRF (plus sécurisé) #}
                        <form method="post" action="{{ path('admin_seance_supprimer', {id: s.id}) }}" onsubmit="return confirm('Supprimer cette séance ?');" style="display:inline-block">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.id) }}">
                            <button class="btn-action btn-action-delete" title="Supprimer">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="text-center py-4">Aucune séance enregistrée pour le moment.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}