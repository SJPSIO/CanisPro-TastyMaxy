{% extends 'admin/base_admin.html.twig' %}

{% block title %}Nouvelle séance – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <a href="{{ path('app_admin_seances') }}" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Planifier une séance</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card card-canis">
            <div class="card-body p-4">
                {# Ajout de la méthode POST #}
                <form class="form-canis" method="POST">
                    <div class="mb-3">
                        <label class="form-label"><i class="fa-solid fa-graduation-cap me-2" style="color:var(--orange)"></i>Cours associé</label>
                        {# Ajout du name="cours_id" #}
                        <select class="form-select" name="cours_id" required>
                            <option value="">-- Choisir un cours --</option>
                            {% for c in cours %}
                            <option value="{{ c.id }}">{{ c.titre }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label"><i class="fa-regular fa-calendar me-2" style="color:var(--orange)"></i>Date</label>
                            {# Ajout du name="date" #}
                            <input type="date" class="form-control" name="date" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label"><i class="fa-regular fa-clock me-2" style="color:var(--orange)"></i>Heure</label>
                            {# Ajout du name="heure" #}
                            <input type="time" class="form-control" name="heure" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><i class="fa-solid fa-location-dot me-2" style="color:var(--orange)"></i>Lieu</label>
                        {# Ajout du name="lieu" #}
                        <input type="text" class="form-control" name="lieu" placeholder="ex : Terrain principal" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label"><i class="fa-solid fa-users me-2" style="color:var(--orange)"></i>Nombre de places max</label>
                        {# Ajout du name="nb_places_max" #}
                        <input type="number" class="form-control" name="nb_places_max" value="15" min="1" max="15" required>
                        <div class="form-text">Maximum 15 places pour un cours collectif, 1 pour un individuel.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-canispro">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Créer la séance
                        </button>
                        <a href="{{ path('app_admin_seances') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}