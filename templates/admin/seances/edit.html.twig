{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier séance – Admin{% endblock %}

{% block admin_body %}

<div class="mb-4">
    <a href="{{ path('app_admin_seances') }}" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
    <h2 style="font-family:'Montserrat',sans-serif;font-weight:800">Modifier la séance</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card card-canis">
            <div class="card-body p-4">
                {# Pense à ajouter la méthode POST et l'action si tu ne l'as pas encore fait #}
                <form class="form-canis" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Cours associé</label>
                        <select class="form-select" name="cours_id">
                            {% for c in cours %}
                                {# Correction : on compare c.id avec l'id du cours de la séance #}
                                <option value="{{ c.id }}" {% if seance.cours and c.id == seance.cours.id %}selected{% endif %}>
                                    {{ c.titre }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label">Date</label>
                            {# Correction : dateHeure formaté pour le champ HTML date #}
                            <input type="date" class="form-control" name="date" value="{{ seance.dateHeure|date('Y-m-d') }}">
                        </div>
                        <div class="col-6">
                            <label class="form-label">Heure</label>
                            {# Correction : dateHeure formaté pour le champ HTML time #}
                            <input type="time" class="form-control" name="heure" value="{{ seance.dateHeure|date('H:i') }}">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Lieu</label>
                        <input type="text" class="form-control" name="lieu" value="{{ seance.lieu }}">
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Places max</label>
                        {# Correction : utilisation du nom exact nbPlacesMax #}
                        <input type="number" class="form-control" name="nb_places_max" value="{{ seance.nbPlacesMax }}">
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-canispro">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Enregistrer
                        </button>
                        <a href="{{ path('app_admin_seances') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}